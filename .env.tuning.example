# Development Environment (Default)
# In-memory Redis, short timeouts, low session limits
# Use for: Local development, testing

# Basic Configuration
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000

# Redis Connection (same container network - low latency)
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_KEEPALIVE=true
REDIS_MAX_RETRIES=3
REDIS_RETRY_BACKOFF_MS=100

# Authentication (disabled by default for dev)
JWT_REQUIRED=false
# BFF_API_KEY=  # Uncomment to enable optional API key


# ============================================================================
# STAGING ENVIRONMENT
# Balanced configuration: moderate memory, more resilient connections
# Uncomment the section below and comment out Development section
# 
# SESSION_TTL_SECONDS=1800
# MAX_SESSIONS=5000
# 
# REDIS_SOCKET_CONNECT_TIMEOUT=10.0
# REDIS_SOCKET_TIMEOUT=10.0
# REDIS_SOCKET_KEEPALIVE=true
# REDIS_MAX_RETRIES=5
# REDIS_RETRY_BACKOFF_MS=100
# 
# JWT_REQUIRED=false
# ============================================================================


# ============================================================================
# PRODUCTION ENVIRONMENT (EXAMPLE)
# High resilience: longer timeouts, more retries, memory-bounded
# Requires external Redis with persistence
# 
# SESSION_TTL_SECONDS=900
# MAX_SESSIONS=10000
# 
# REDIS_URL=redis://<your-redis-host>:6379/0
# REDIS_SOCKET_CONNECT_TIMEOUT=15.0
# REDIS_SOCKET_TIMEOUT=15.0
# REDIS_SOCKET_KEEPALIVE=true
# REDIS_MAX_RETRIES=10
# REDIS_RETRY_BACKOFF_MS=200
# 
# JWT_REQUIRED=true
# JWT_SECRET=<your-production-secret>
# JWT_ISSUER=https://your-domain.com
# JWT_AUDIENCE=log-analyzer-api
# 
# BFF_API_KEY=<strong-api-key-for-public-endpoints>
# INTERNAL_API_TOKEN=<different-token-for-internal-services>
# ============================================================================
